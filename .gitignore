# Per-machine, per-run artifacts
.claude/team/runs/*/
.claude/team/runs/_*
.claude/team/status/*.env
.claude/team/runs/leader-*.md
.claude/team/plans/*.md
!.claude/team/runs/.gitkeep
!.claude/team/runs/.gitignore
!.claude/team/status/.gitkeep

# Memory vault notes — project-specific, generated per project
.claude/memory/architecture/A-*.md
.claude/memory/features/F-*.md
.claude/memory/fixes/X-*.md
.claude/memory/bugs/B-*.md

# Local Claude / DeepSeek caches that may hold credentials
.deepseek/
.claude/.cache/
.claude/projects/

# User preferences — personal, never commit
.claude/memory/user-prefs/*
!.claude/memory/user-prefs/.gitkeep

# Standard
.env
.env.local
.env.*.local
node_modules/
*.log

# Task queue — per-run artifacts (skeleton dirs + README only tracked)
.claude/team/queue/pending/*
.claude/team/queue/claimed/*
.claude/team/queue/done/*
.claude/team/queue/failed/*
!.claude/team/queue/pending/.gitkeep
!.claude/team/queue/claimed/.gitkeep
!.claude/team/queue/done/.gitkeep
!.claude/team/queue/failed/.gitkeep
!.claude/team/queue/pending/.gitignore
!.claude/team/queue/claimed/.gitignore
!.claude/team/queue/done/.gitignore
!.claude/team/queue/failed/.gitignore
